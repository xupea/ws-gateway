PORT=3000
NODE_ID=node-1

# connection_init 的 accessToken / lockdownToken 验证接口
AUTH_TOKEN_VALIDATE_URL=http://localhost:8080/internal/token/validate
AUTH_TIMEOUT_MS=3000
# 本地调试：跳过认证，直接认为 token 有效
DEV_AUTH_BYPASS=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=ws.push
RABBITMQ_PREFETCH=100
RABBITMQ_MESSAGE_TTL_MS=30000  # 消息 TTL（ms），节点宕机时过期消息自动丢弃
RABBITMQ_BINDING_WEIGHT=10     # 一致性哈希绑定权重，所有节点相同即可
