PORT=3000
NODE_ID=node-1

# Java 认证接口
AUTH_VALIDATE_URL=http://localhost:8080/internal/session/validate
SESSION_COOKIE_NAME=session
AUTH_TIMEOUT_MS=3000
# 本地调试：跳过认证，直接用 session cookie 的值作为 userId
DEV_AUTH_BYPASS=false

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=ws.push
RABBITMQ_PREFETCH=100
