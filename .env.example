PORT=3000
NODE_ID=node-1
WS_IDLE_TIMEOUT_SEC=120
SHUTDOWN_GRACE_MS=10000

# Java 认证接口
AUTH_VALIDATE_URL=http://localhost:8080/internal/session/validate
# connection_init 的 accessToken 验证接口
AUTH_TOKEN_VALIDATE_URL=http://localhost:8080/internal/token/validate
SESSION_COOKIE_NAME=session
AUTH_TIMEOUT_MS=3000
# 本地调试：跳过认证，直接用 accessToken 作为 userId
DEV_AUTH_BYPASS=false

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_INGRESS_CHANNEL=ws:push
